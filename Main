    <div class="active-prompt" id="active-prompt-text">"Share a favorite memory with the couple"</div>
    <div class="video-preview">
      <video id="record-video" autoplay muted playsinline></video>
      <div class="record-overlay">
        <div class="timer-bar"><div class="timer-fill" id="timer-fill"></div></div>
        <div class="timer-text" id="timer-text"><span class="rec-dot" id="rec-dot" style="display:none"></span><span id="timer-display">00:30</span></div>
      </div>
    </div>
    <div class="row">
      <button class="gold-btn" id="record-btn" onclick="toggleRecording()">Start Recording</button>
      <button class="outline-btn" id="submit-video-btn" onclick="submitVideo()" style="display:none">Submit Message</button>
    </div>
  </div>
</div>

<!-- ======================== -->
<!-- SCREEN 4: PHOTO BOOTH    -->
<!-- ======================== -->
<div class="screen" id="photo-booth">
  <div class="screen-header">
    <div class="screen-logo">Calling the Shots</div>
    <button class="back-btn" onclick="stopCamera(); showScreen('welcome')">← Back</button>
  </div>
  <div class="screen-body">
    <div class="screen-title" id="photo-screen-title">Get Ready!</div>
    <div class="photo-dots">
      <div class="dot" id="dot-1"></div>
      <div class="dot" id="dot-2"></div>
      <div class="dot" id="dot-3"></div>
      <div class="dot" id="dot-4"></div>
    </div>
    <div class="photo-preview">
      <video id="photo-video" autoplay muted playsinline></video>
      <canvas id="photo-canvas" style="display:none"></canvas>
      <div class="photo-countdown" id="photo-countdown"></div>
    </div>
    <div class="photo-strip" id="photo-strip">
      <div class="strip-photo" id="ph1"><div class="strip-number">1</div></div>
      <div class="strip-photo" id="ph2"><div class="strip-number">2</div></div>
      <div class="strip-photo" id="ph3"><div class="strip-number">3</div></div>
      <div class="strip-photo" id="ph4"><div class="strip-number">4</div></div>
    </div>
    <button class="gold-btn" id="photo-action-btn" onclick="runPhotoSession()">Take Photos</button>
  </div>
</div>

<!-- ======================== -->
<!-- SCREEN 5: PHONE NUMBER   -->
<!-- ======================== -->
<div class="screen" id="phone-screen">
  <div class="screen-header">
    <div class="screen-logo">Calling the Shots</div>
  </div>
  <div class="screen-body">
    <div class="screen-title">Get Your Photos!</div>
    <div class="screen-sub">Enter your number and we'll text your strip</div>
    <div class="gold-divider"></div>
    <div class="phone-input-wrap">
      <input class="phone-input" type="tel" id="phone-input" placeholder="(555) 000-0000" maxlength="14" oninput="formatPhone(this)">
      <div class="row">
        <button class="outline-btn" onclick="skipPhone()">Skip</button>
        <button class="gold-btn" onclick="sendPhotos()">Send & Print</button>
      </div>
    </div>
    <div class="screen-sub" style="font-size:12px;margin-top:8px;">Your photos are always saved for the couple 💛</div>
  </div>
</div>

<!-- ======================== -->
<!-- SCREEN 6: THANK YOU      -->
<!-- ======================== -->
<div class="screen" id="thankyou">
  <div class="beam"></div>
  <div class="light-point"></div>
  <div class="vignette"></div>

  <div class="thankyou-content">
    <div class="thankyou-icon" id="thankyou-icon">🥂</div>
    <div class="thankyou-title">Thank You!</div>
    <div class="screen-sub" id="thankyou-message">Your message has been saved for the couple.</div>
    <div class="gold-divider"></div>
    <div class="countdown-back" id="countdown-back">Returning in 10...</div>
  </div>
</div>

<script>
  // =====================
  // STATE
  // =====================
  let selectedPromptIndex = 0;
  let mediaRecorder = null;
  let recordedChunks = [];
  let recordingTimer = null;
  let recordingSeconds = 30;
  let isRecording = false;
  let photoStream = null;
  let capturedPhotos = [];
  const MAX_PHOTOS = 4;

  const prompts = [
    "Share a favorite memory with the couple",
    "What's your best advice for their marriage?",
    "Share a wish for their future together",
    "Say whatever is in your heart right now"
  ];

  // =====================
  // SCREEN NAV
  // =====================
  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById(id).classList.add('active');

    if (id === 'video-record') startCamera('record-video');
    if (id === 'video-prompts') resetVideoUI();
  }

  // =====================
  // PROMPT SELECTION
  // =====================
  function selectPrompt(index, el) {
    document.querySelectorAll('.prompt-btn').forEach(b => b.classList.remove('selected'));
    el.classList.add('selected');
    selectedPromptIndex = index;
    document.getElementById('active-prompt-text').textContent = `"${prompts[index]}"`;
    const btn = document.getElementById('start-record-btn');
    btn.style.opacity = '1';
    btn.style.pointerEvents = 'all';
  }

  // =====================
  // CAMERA
  // =====================
  async function startCamera(videoId) {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: 'user', width: { ideal: 1280 }, height: { ideal: 720 } },
        audio: videoId === 'record-video'
      });
      const video = document.getElementById(videoId);
      video.srcObject = stream;
      if (videoId === 'photo-video') photoStream = stream;
      return stream;
    } catch(e) {
      console.error('Camera error:', e);
    }
  }

  function stopCamera() {
    if (photoStream) {
      photoStream.getTracks().forEach(t => t.stop());
      photoStream = null;
    }
  }

  // =====================
  // VIDEO RECORDING
  // =====================
  async function toggleRecording() {
    if (!isRecording) {
      await startVideoRecording();
    } else {
      stopRecording();
    }
  }

  async function startVideoRecording() {
    recordedChunks = [];
    const stream = document.getElementById('record-video').srcObject;
    if (!stream) return;

    mediaRecorder = new MediaRecorder(stream);
    mediaRecorder.ondataavailable = e => {
      if (e.data.size > 0) recordedChunks.push(e.data);
    };
    mediaRecorder.onstop = () => {
      document.getElementById('submit-video-btn').style.display = 'block';
    };
    mediaRecorder.start();
    isRecording = true;

    document.getElementById('record-btn').textContent = 'Stop Recording';
    document.getElementById('rec-dot').style.display = 'inline-block';

    recordingSeconds = 30;
    updateTimer();
    recordingTimer = setInterval(() => {
      recordingSeconds--;
      updateTimer();
      if (recordingSeconds <= 0) stopRecording();
    }, 1000);
  }

  function stopRecording() {
    if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
    clearInterval(recordingTimer);
    isRecording = false;
    document.getElementById('record-btn').textContent = 'Re-record';
    document.getElementById('rec-dot').style.display = 'none';
    document.getElementById('timer-fill').style.width = '0%';
    document.getElementById('timer-display').textContent = '00:30';
  }

  function updateTimer() {
    const pct = ((30 - recordingSeconds) / 30) * 100;
    document.getElementById('timer-fill').style.width = pct + '%';
    const s = recordingSeconds < 10 ? '0' + recordingSeconds : recordingSeconds;
    document.getElementById('timer-display').textContent = `00:${s}`;
  }

  function resetVideoUI() {
    document.getElementById('start-record-btn').style.opacity = '0.3';
    document.getElementById('start-record-btn').style.pointerEvents = 'none';
    document.querySelectorAll('.prompt-btn').forEach(b => b.classList.remove('selected'));
  }

  function submitVideo() {
    // Save video blob
    const blob = new Blob(recordedChunks, { type: 'video/webm' });
    // In production: upload to Google Drive via API
    console.log('Video saved:', blob.size, 'bytes');
    stopRecording();
    showThankyou('video');
  }

  // =====================
  // PHOTO BOOTH
  // =====================
  async function startPhotoSession() {
    capturedPhotos = [];
    resetPhotoUI();
    showScreen('photo-booth');
    await startCamera('photo-video');
  }

  function resetPhotoUI() {
    for (let i = 1; i <= 4; i++) {
      const ph = document.getElementById('ph' + i);
      ph.innerHTML = `<div class="strip-number">${i}</div>`;
    }
    document.querySelectorAll('.dot').forEach(d => d.classList.remove('filled'));
    document.getElementById('photo-screen-title').textContent = 'Get Ready!';
    document.getElementById('photo-action-btn').style.display = 'block';
    document.getElementById('photo-action-btn').textContent = 'Take Photos';
  }

  async function runPhotoSession() {
    document.getElementById('photo-action-btn').style.display = 'none';
    capturedPhotos = [];

    for (let i = 0; i < MAX_PHOTOS; i++) {
      document.getElementById('photo-screen-title').textContent = `Photo ${i + 1} of 4`;
      await countdown(3);
      capturePhoto(i);
      await sleep(800);
    }

    document.getElementById('photo-screen-title').textContent = 'Looking good! 🎉';
    stopCamera();
    await sleep(1000);
    showScreen('phone-screen');
  }

  function capturePhoto(index) {
    const video = document.getElementById('photo-video');
    const canvas = document.getElementById('photo-canvas');
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    const ctx = canvas.getContext('2d');
    ctx.scale(-1, 1);
    ctx.drawImage(video, -canvas.width, 0);

    const dataUrl = canvas.toDataURL('image/jpeg', 0.9);
    capturedPhotos.push(dataUrl);

    // Show in strip
    const ph = document.getElementById('ph' + (index + 1));
    ph.innerHTML = `<img src="${dataUrl}"><div class="strip-number">${index + 1}</div>`;
    document.getElementById('dot-' + (index + 1)).classList.add('filled');

    // Flash
    triggerFlash();
  }

  function triggerFlash() {
    const flash = document.getElementById('flash');
    flash.classList.add('active');
    setTimeout(() => flash.classList.remove('active'), 400);
  }

  async function countdown(seconds) {
    const overlay = document.getElementById('countdown-overlay');
    const num = document.getElementById('countdown-num');
    overlay.classList.add('active');

    for (let i = seconds; i >= 1; i--) {
      num.textContent = i;
      num.style.animation = 'none';
      num.offsetHeight; // reflow
      num.style.animation = 'countPop 0.8s ease forwards';
      await sleep(900);
    }

    overlay.classList.remove('active');
    await sleep(100);
  }

  function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  // =====================
  // PHONE + SEND
  // =====================
  function formatPhone(input) {
    let val = input.value.replace(/\D/g, '');
    if (val.length >= 6) val = `(${val.slice(0,3)}) ${val.slice(3,6)}-${val.slice(6,10)}`;
    else if (val.length >= 3) val = `(${val.slice(0,3)}) ${val.slice(3)}`;
    input.value = val;
  }

  function sendPhotos() {
    const phone = document.getElementById('phone-input').value;
    // In production: send via Twilio + save to Google Drive
    console.log('Sending photos to:', phone);
    console.log('Photos:', capturedPhotos.length);
    showThankyou('photo');
  }

  function skipPhone() {
    // Save to cloud only
    console.log('Saving to cloud only:', capturedPhotos.length, 'photos');
    showThankyou('photo');
  }

  // =====================
  // THANK YOU
  // =====================
  function showThankyou(type) {
    if (type === 'video') {
      document.getElementById('thankyou-icon').textContent = '🎥';
      document.getElementById('thankyou-message').textContent = 'Your message has been saved for the couple.';
    } else {
      document.getElementById('thankyou-icon').textContent = '📸';
      document.getElementById('thankyou-message').textContent = 'Your photos have been printed and sent!';
    }
    showScreen('thankyou');
    startReturnCountdown();
  }

  function startReturnCountdown() {
    let seconds = 10;
    const el = document.getElementById('countdown-back');
    const interval = setInterval(() => {
      seconds--;
      el.textContent = `Returning in ${seconds}...`;
      if (seconds <= 0) {
        clearInterval(interval);
        showScreen('welcome');
      }
    }, 1000);
  }
</script>
</body>
</html>
